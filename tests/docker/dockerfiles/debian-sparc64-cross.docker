#
# Docker sparc64 cross-compiler target
#
# This is a minimal, self-contained cross environment for sparc64. It is
# NOT generated by lcitool: it provides only the Debian sparc64 cross
# toolchain (compiler + cross libc) plus a manually cross-compiled glib,
# which is enough to configure and build QEMU for a sparc64 host.
#
# glib and its mandatory dependencies (libffi, pcre2, zlib) are built from
# the glib meson subproject wraps, so no sparc64 :native packages are needed.
#
FROM docker.io/library/debian:13-slim

ENV CROSS_PREFIX=sparc64-linux-gnu
ENV CROSS_SYSROOT=/usr/sparc64-linux-gnu

RUN export DEBIAN_FRONTEND=noninteractive && \
    apt-get update && \
    apt-get install -y eatmydata && \
    eatmydata apt-get dist-upgrade -y && \
    eatmydata apt-get install --no-install-recommends -y \
        bison \
        build-essential \
        bzip2 \
        ca-certificates \
        ccache \
        curl \
        flex \
        gcc \
        gcc-sparc64-linux-gnu \
        gettext \
        git \
        libc6-dev-sparc64-cross \
        libglib2.0-dev \
        make \
        ninja-build \
        pkgconf \
        python3 \
        python3-pip \
        python3-setuptools \
        python3-venv \
        python3-wheel \
        xz-utils && \
    eatmydata apt-get autoremove -y && \
    eatmydata apt-get autoclean -y && \
    rm -f /usr/lib*/python3*/EXTERNALLY-MANAGED

RUN /usr/bin/pip3 install meson==1.8.1

# pkg-config wrapper for the sparc64 host: only looks at the cross sysroot,
# so it never picks up host (x86) .pc files.
RUN printf '#!/bin/sh\n\
export PKG_CONFIG_DIR=\n\
export PKG_CONFIG_LIBDIR=%s/lib/pkgconfig:%s/share/pkgconfig\n\
exec pkgconf "$@"\n' "${CROSS_SYSROOT}" "${CROSS_SYSROOT}" \
        > /usr/bin/sparc64-linux-gnu-pkg-config && \
    chmod +x /usr/bin/sparc64-linux-gnu-pkg-config

# Meson cross file describing the sparc64 (big-endian) host.
RUN mkdir -p /usr/local/share/meson/cross && \
    printf "[binaries]\n\
c = '/usr/bin/sparc64-linux-gnu-gcc'\n\
cpp = '/usr/bin/sparc64-linux-gnu-g++'\n\
ar = '/usr/bin/sparc64-linux-gnu-gcc-ar'\n\
strip = '/usr/bin/sparc64-linux-gnu-strip'\n\
pkgconfig = '/usr/bin/sparc64-linux-gnu-pkg-config'\n\
pkg-config = '/usr/bin/sparc64-linux-gnu-pkg-config'\n\
\n\
[host_machine]\n\
system = 'linux'\n\
cpu_family = 'sparc64'\n\
cpu = 'sparc64'\n\
endian = 'big'\n" > /usr/local/share/meson/cross/sparc64-linux-gnu

# Cross-compile glib into the cross sysroot. Its mandatory dependencies
# (libffi, pcre2, zlib) are pulled in as meson subprojects (forcefallback),
# so nothing extra needs to be installed for the target.
RUN cd /tmp && \
    curl -#SL https://download.gnome.org/sources/glib/2.89/glib-2.89.2.tar.xz | tar -xJ && \
    cd glib-2.89.2 && \
    meson setup _build \
        --cross-file=/usr/local/share/meson/cross/sparc64-linux-gnu \
        --prefix=${CROSS_SYSROOT} \
        --libdir=lib \
        --buildtype=release \
        --wrap-mode=forcefallback \
        --default-library=both \
        -Dtests=false \
        -Dnls=disabled \
        -Dlibmount=disabled \
        -Dselinux=disabled \
        -Dman-pages=disabled \
        -Ddtrace=disabled \
        -Dsysprof=disabled \
        -Dintrospection=disabled \
        -Dpcre2:jit=disabled && \
    ninja -C _build && \
    ninja -C _build install && \
    cd /tmp && rm -rf glib-2.89.2

ENV ABI="sparc64-linux-gnu"
ENV MESON_OPTS="--cross-file=sparc64-linux-gnu"
ENV PKG_CONFIG_PATH="${CROSS_SYSROOT}/lib/pkgconfig"
ENV QEMU_CONFIGURE_OPTS="--cross-prefix=sparc64-linux-gnu-"
ENV DEF_TARGET_LIST=sparc64-softmmu,sparc64-linux-user
ENV MAKE=/usr/bin/make
ENV NINJA=/usr/bin/ninja
ENV PYTHON=/usr/bin/python3

# As a final step configure the user (if env is defined)
ARG USER
ARG UID
RUN if [ "${USER}" ]; then \
  id ${USER} 2>/dev/null || useradd -u ${UID} -U ${USER}; fi
